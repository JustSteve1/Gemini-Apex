# ── Apex Environment Variables ────────────────────────
# Copy to .env.local for local dev, or set in Cloud Run

# Google Gemini API Key
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=

# Google Cloud Project ID (where BigQuery lives)
GCP_PROJECT_ID=

# BigQuery dataset name (default: f1_telemetry)
BQ_DATASET=f1_telemetry

# BigQuery location (default: US)
BQ_LOCATION=US

# Option A: Path to service account key file (local dev)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Option B: Service account key JSON string (Cloud Run — set as secret)
# GCP_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
