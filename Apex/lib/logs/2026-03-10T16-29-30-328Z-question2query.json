  "sql": "SELECT DISTINCT\n    t1.compound,\n    t1.session_type,\n    t1.race_name\nFROM\n    f1_data_library_DS.laps_clean AS t1\nJOIN\n    f1_data_library_DS.public_drivers AS t2\nON\n    t1.driver_id = t2.driver_id\nWHERE\n    t2.driver_code = 'VER'\n    AND t1.season = 2026\nORDER BY\n    t1.session_type, t1.race_name, t1.compound\nLIMIT 50"
